# Copy to .env and fill in as needed. Nothing here is required to run the demo.

# Used to sign JWTs. Any random string works for local demo use.
JWT_SECRET=change-me-to-a-random-string

# Optional. If unset, AI trade explanations fall back to a template-based
# paragraph instead of calling the Claude API.
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite by default — fine for local development.
# IMPORTANT: SQLite is stored inside the container filesystem and is wiped on
# every redeploy. If you are deploying to Render, Railway, Fly.io, or any
# container-based host you MUST either:
#   1. Mount a persistent volume and point DATABASE_URL at the file inside it, OR
#   2. Switch to a managed Postgres database (recommended):
#        DATABASE_URL=postgresql://user:password@host:5432/dbname
#
# On Render: add a "PostgreSQL" service, copy the Internal Database URL, and
# set it as DATABASE_URL in your web service's environment variables.
# On Railway: add a Postgres plugin, copy DATABASE_URL from its Variables tab.
# On Fly.io: run `fly postgres create` and use the connection string it gives.
DATABASE_URL=sqlite:///./trading_demo.db

# Seeded automatically on startup if no admin account exists yet. Change the
# password before deploying this anywhere beyond your own machine.
ADMIN_EMAIL=admin@aitradingmentor.demo
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=Platform Admin
