# Copy to .env and fill in as needed. Nothing here is required to run the demo.

# Used to sign JWTs. Any random string works for local demo use.
JWT_SECRET=change-me-to-a-random-string

# Optional. If unset, AI trade explanations fall back to a template-based
# paragraph instead of calling the Claude API.
ANTHROPIC_API_KEY=

# SQLite by default; point at a Postgres URL to use Postgres instead.
DATABASE_URL=sqlite:///./trading_demo.db

# Seeded automatically on startup if no admin account exists yet. Change the
# password before deploying this anywhere beyond your own machine.
ADMIN_EMAIL=admin@aitradingmentor.demo
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=Platform Admin
